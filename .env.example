# =========================
# Server SSH
# =========================
SERVER_HOST=your-server-ip
SERVER_PORT=22
SERVER_USER=root
SERVER_PASSWORD=your-ssh-password

# =========================
# WordPress
# =========================
WP_PATH=/www/wwwroot/your-site
WP_URL=https://example.com
WP_REST_BASE=https://example.com/wp-json/myblog/v1
WP_USE_REST_API=0
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=your-admin-password
WP_API_KEY=your-api-key
WP_APP_PASSWORD=your-app-password

# =========================
# Database
# =========================
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_CHARSET=utf8mb4
DB_TABLE_PREFIX=blog_

# =========================
# Paths
# =========================
LOCAL_PROJECT_DIR=D:/path/to/project
LOCAL_WWWROOT=D:/path/to/project/wwwroot
SERVER_WWWROOT=/www/wwwroot/your-site
BACKUP_PATH=/root/wp_backups
LOG_PATH=/var/log/aibase_publish.log

# =========================
# Schedules
# =========================
CRON_MORNING=0 9 * * *
CRON_EVENING=0 18 * * *

# =========================
# Collector
# =========================
COLLECTION_MIN_CONTENT_LENGTH=200
COLLECTION_MAX_CONTENT_LENGTH=50000
COLLECTION_DELAY_BETWEEN_REQUESTS=2

# Optional: token for AIBase API mode
AIBASE_API_TOKEN=
