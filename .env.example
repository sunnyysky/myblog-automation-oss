# =========================
# Server SSH
# =========================
SERVER_HOST=your-server-ip
SERVER_PORT=22
SERVER_USER=root
SERVER_PASSWORD=your-ssh-password

# =========================
# WordPress
# =========================
WP_PATH=/www/wwwroot/your-site
WP_URL=https://example.com
WP_REST_BASE=https://example.com/wp-json/myblog/v1
WP_USE_REST_API=0
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=your-admin-password
WP_API_KEY=your-api-key
WP_APP_PASSWORD=your-app-password

# =========================
# Database
# =========================
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_CHARSET=utf8mb4
DB_TABLE_PREFIX=blog_

# =========================
# Paths
# =========================
LOCAL_PROJECT_DIR=D:/path/to/project
LOCAL_WWWROOT=D:/path/to/project/wwwroot
SERVER_WWWROOT=/www/wwwroot/your-site
BACKUP_PATH=/root/wp_backups
LOG_PATH=/var/log/aibase_publish.log

# =========================
# Schedules
# =========================
CRON_MORNING=0 9 * * *
CRON_EVENING=0 18 * * *

# =========================
# Collector
# =========================
COLLECTION_MIN_CONTENT_LENGTH=200
COLLECTION_MAX_CONTENT_LENGTH=50000
COLLECTION_DELAY_BETWEEN_REQUESTS=2

# Optional: token for AIBase API mode
AIBASE_API_TOKEN=

# =========================
# External Feed Auto Update
# =========================
# JSON array, e.g.
# EXTERNAL_FEEDS=[{"name":"OpenAI News","url":"https://openai.com/news/rss.xml","type":"rss"},{"name":"Hacker News","url":"https://hnrss.org/frontpage","type":"rss"}]
EXTERNAL_FEEDS=
EXTERNAL_FEED_POST_STATUS=publish
EXTERNAL_FEED_CATEGORY_SLUG=external-updates
EXTERNAL_FEED_CATEGORY_NAME=外部数据更新
EXTERNAL_FEED_TAGS=外部数据,自动更新
EXTERNAL_FEED_TITLE_TEMPLATE=每日外部数据速递 | {date}
EXTERNAL_FEED_USE_HELPER_ENDPOINT=1
EXTERNAL_FEED_HELPER_URL=https://example.com/wp_publish_helper.php
EXTERNAL_FEED_MAX_ITEMS_PER_SOURCE=4
EXTERNAL_FEED_MAX_ITEMS_TOTAL=18
EXTERNAL_FEED_LOOKBACK_DAYS=3
EXTERNAL_FEED_HISTORY_KEEP_DAYS=30
EXTERNAL_FEED_ALLOW_MULTI_POST_PER_DAY=0
EXTERNAL_FEED_REQUEST_TIMEOUT=25
EXTERNAL_FEED_HISTORY_FILE=wwwroot/runtime/external_feed_history.json

# =========================
# AIBase Cases Pipeline
# =========================
AIBASE_CASES_ENABLED=1
AIBASE_CASES_FLAG=zh
AIBASE_CASES_TYPE=5
AIBASE_CASES_PAGE_SIZE=50
AIBASE_CASES_BATCH_SIZE=40
AIBASE_CASES_MIN_TEXT_LEN=180
AIBASE_CASES_TITLE_MIN_LEN=8
AIBASE_CASES_TITLE_MAX_LEN=80
AIBASE_CASES_REQUIRE_THUMB=1
AIBASE_CASES_DRAFT_STATUS=draft
AIBASE_CASES_CATEGORY=AI案例
AIBASE_CASES_CATEGORY_SLUG=ai-cases
AIBASE_CASES_TAGS=AI案例,案例拆解,AI变现
AIBASE_CASES_USE_SOURCE_TAGS=0
AIBASE_CASES_INCLUDE_META_IN_CONTENT=0
AIBASE_CASES_INCLUDE_SOURCE_TAGS_IN_CONTENT=0
AIBASE_CASES_NO_SOURCE_LINK=1
AIBASE_CASES_SLEEP_SECONDS=1
AIBASE_CASES_HISTORY_FILE=wwwroot/runtime/aibase_cases_history.json
AIBASE_CASES_PUBLISH_HISTORY_FILE=wwwroot/runtime/publish_history_cases.json
AIBASE_CASES_DAILY_MAX=3
AIBASE_CASES_MORNING_COUNT=2
AIBASE_CASES_EVENING_COUNT=1
AIBASE_CASES_COLLECT_LOG=/var/log/aibase_cases_collect.log
AIBASE_CASES_PUBLISH_LOG=/var/log/aibase_cases_publish.log
